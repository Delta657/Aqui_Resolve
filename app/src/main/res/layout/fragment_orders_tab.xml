<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Lista de Pedidos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:nestedScrollingEnabled="true"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Estado Vazio -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_orders"
            android:background="@drawable/circle_background_primary"
            android:padding="24dp"
            app:tint="@color/white"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhum pedido encontrado"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvEmptyMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Você ainda não fez nenhum pedido. Que tal solicitar um serviço?"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewOrder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fazer Primeiro Pedido"
            android:textSize="14sp"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/primary_color"
            android:textColor="@color/white"
            android:padding="12dp" />

    </LinearLayout>

    <!-- Estado de Carregamento -->
    <LinearLayout
        android:id="@+id/loadingState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/primary_color"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carregando pedidos..."
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</FrameLayout>











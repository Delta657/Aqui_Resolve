rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil
    match /profile_images/{userId}/{fileName} {
      // Todos logados podem ver
      allow read: if request.auth != null;
      // Apenas o dono pode atualizar sua foto e apenas imagens
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens de serviços
    match /service_images/{serviceId}/{fileName} {
      // Todos logados podem ver
      allow read: if request.auth != null;
      // Qualquer usuário logado pode enviar
      allow write: if request.auth != null && request.resource.contentType.matches('image/.*');
    }

    // Imagens do chat (associadas ao pedido)
    match /chat_images/{orderId}/{fileName} {
      // Apenas cliente ou prestador atribuído podem ler ou enviar (apenas imagens)
      allow read, write: if request.auth != null
        && exists(/databases/(default)/documents/orders/$(orderId))
        && (
          request.auth.uid == get(/databases/(default)/documents/orders/$(orderId)).data.clientId ||
          request.auth.uid == get(/databases/(default)/documents/orders/$(orderId)).data.assignedProvider
        )
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens de pedidos
    match /order_images/{orderId}/{fileName} {
      // Todos logados podem ver
      allow read: if request.auth != null;
      // Apenas o criador do pedido pode enviar imagens
      allow write: if request.auth != null
        && exists(/databases/(default)/documents/orders/$(orderId))
        && request.auth.uid == get(/databases/(default)/documents/orders/$(orderId)).data.clientId
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens de pedidos (pasta "Pedidos" para compatibilidade com bucket atual)
    match /Pedidos/{orderId}/{fileName} {
      // Todos logados podem ver
      allow read: if request.auth != null;
      // Apenas o criador do pedido pode enviar imagens
      allow write: if request.auth != null
        && exists(/databases/(default)/documents/orders/$(orderId))
        && request.auth.uid == get(/databases/(default)/documents/orders/$(orderId)).data.clientId
        && request.resource.contentType.matches('image/.*');
    }

            // Documentos de prestadores - pasta "Documentos"
            match /Documentos/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }

            // Selfies de prestadores - pasta "selfies"
            match /selfies/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }

            // Selfies de prestadores - pasta "Selfie" (compatibilidade)
            match /Selfie/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }
  }
}
